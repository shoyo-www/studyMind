QUIZ_GEMINI_FALLBACK_MODEL=gemini-2.5-flash-lite

VITE_API_URL=/api
ALLOWED_ORIGIN=http://localhost:5173,https://yourdomain.com

# Groq — free fallback when Gemini quota is hit
# Get free key at: console.groq.com (no credit card needed, works in India)
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_FALLBACK_MODEL=llama-3.1-8b-instant